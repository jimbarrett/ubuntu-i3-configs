#!/bin/sh

bt_power() {
	bluetoothctl show 2>/dev/null | grep "Powered:" | awk '{print $2}'
}

bt_connected() {
	bluetoothctl devices Connected 2>/dev/null | cut -d' ' -f3-
}

case $BLOCK_BUTTON in
	1)
		# Open blueman-manager for full device management (pair, connect, etc.)
		blueman-manager >/dev/null 2>&1 &
		;;
	3)
		powered=$(bt_power)
		if [ "$powered" = "yes" ]; then
			bluetoothctl power off > /dev/null 2>&1
			notify-send "Bluetooth" "Powered off"
		else
			bluetoothctl power on > /dev/null 2>&1
			notify-send "Bluetooth" "Powered on"
		fi
		pkill -RTMIN+11 i3blocks
		;;
esac

powered=$(bt_power)
connected=$(bt_connected)

if [ "$powered" != "yes" ]; then
	printf "<span color='#a89984'>&#xf294;  Off</span>\n"
	printf "<span color='#a89984'>&#xf294;</span>\n"
elif [ -n "$connected" ]; then
	label=$(echo "$connected" | head -1)
	printf "&#xf294;  %s\n" "$label"
	printf "&#xf294;\n"
	echo "#83a598"
else
	printf "&#xf294;  On\n"
	printf "&#xf294;\n"
fi
