#!/bin/sh

case $BLOCK_BUTTON in
	1)
		layouts=$(ls "$HOME/.screenlayout" 2>/dev/null)
		if [ -z "$layouts" ]; then
			notify-send "Displays" "No saved layouts.\nRight-click to open arandr and save a layout."
		else
			choice=$(echo "$layouts" | sed 's/\.sh$//' | rofi -dmenu -p "Layout" -i)
			if [ -n "$choice" ]; then
				sh "$HOME/.screenlayout/${choice}.sh" \
					&& feh --bg-fill --no-fehbg ~/.config/wallpapers/village.jpg \
					&& notify-send "Displays" "Switched to: $choice"
			fi
		fi
		;;
	3) arandr & ;;
esac

icon="&#xf26c;"

printf " %s  Displays \n" "$icon"
printf " %s  \n" "$icon"
echo "#d65d0e"
